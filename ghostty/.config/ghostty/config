# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.

command = /usr/bin/zsh
# Fix vi mode's Ctrl+[. By default it clears the line.
# See: https://github.com/ghostty-org/ghostty/discussions/7373
keybind = ctrl+[=text:\x1b
font-family = "Mononoki"
font-size = 12
# Disable ligatures.
font-feature = -calt, -liga, -dlig
adjust-cell-height = 45%
window-padding-balance = true
window-padding-color = extend
window-subtitle = working-directory
theme = "kuromi"
background-opacity = 0.75
background-opacity-cells = true
background-blur = true
custom-shader = ~/.config/ghostty/in-game-crt-cursor.glsl
#custom-shader = ~/.config/ghostty/bloom.glsl
#custom-shader = ~/.config/ghostty/crt.glsl
